void setup() {

  Wire.setSDA(I2C_SDA);
  Wire.setSCL(I2C_SCL);
  Wire.begin();
  display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS);
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.clearDisplay(); 
  
  display.drawBitmap(0, 0, epd_bitmap_nerf, 128, 60, SSD1306_WHITE);
  display.display();

  pinMode(VOLTAGE_PIN, INPUT);

  Serial.begin(9600);
  delay(2000);
  
}

void loop() {
  uint16_t adc_value = analogRead(VOLTAGE_PIN);

  float voltage = (adc_value * 3.3 * (10.0 + 47.0) / 10.0) / (1023.0 * 4);

  uint16_t dart = analogRead(DART_SENSE_PIN);

  Serial.print("voltage: ");
  Serial.print(voltage);
  Serial.print("v\t\t\tdart: ");
  Serial.println(dart);

  display.clearDisplay();
  display.setCursor(0, 0); display.println("cell: " + String(voltage) +"v");
  display.setCursor(0, 25); display.println("pack: " + String(voltage*4) + "v");
  display.setCursor(0, 50); display.println("dart: " + String(dart/4));
  display.display();

 
  
}
